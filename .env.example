# Required for Veo preview generation (npm run generate:previews)
# Get a key at https://aistudio.google.com/apikey — Veo requires a paid Gemini API tier.
GEMINI_API_KEY=

# Optional overrides
# VEO_MODEL=veo-3.0-generate-001
# VEO_MODEL=veo-3.1-generate-preview
# VEO_MODEL=veo-3.0-fast-generate-001
# VEO_DURATION_SECONDS=4
# VEO_RESOLUTION=720p
# VEO_POLL_MS=10000
